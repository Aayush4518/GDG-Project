# ============================================================
# Smart Tourist Safety System — Environment Configuration
# ============================================================
# IMPORTANT: Never commit this file to version control.
# Copy this file to .env and fill in your actual values.
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/smarttourist

# --- Security ---
# Generate a strong secret key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-strong-secret-key-before-running

# --- App ---
DEBUG=False

# --- Dashboard Authority Credentials ---
# Police officer credentials (default for dev only — CHANGE in production)
POLICE_USERNAME=police@travelguardian.gov
POLICE_PASSWORD=police123

# Tourism officer credentials (default for dev only — CHANGE in production)
TOURISM_USERNAME=tourism@travelguardian.gov
TOURISM_PASSWORD=tourism123
